# Copy this to .env and fill in. Never commit the real .env.

# Chat / answering runs on Google Gemini's free tier. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
PINECONE_API_KEY=pcn-...

# Pinecone index name (created automatically on first run)
PINECONE_INDEX=enterprise-docs

# Models (defaults are fine to start).
# Embeddings run locally via fastembed — no API key, no quota.
CHAT_MODEL=gemini-2.5-flash
EMBED_MODEL=BAAI/bge-small-en-v1.5

# Chat endpoint (any OpenAI-compatible provider works: Gemini / Groq / xAI / OpenAI / ...).
CHAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# How many chunks to retrieve per question
TOP_K=5

# Only needed if you use the Telegram chat interface
TELEGRAM_BOT_TOKEN=
